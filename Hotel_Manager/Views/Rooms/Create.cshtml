@model Hotel_Manager.Models.Room

@{
    ViewData["Title"] = "Create Room";
}

<h1>Create New Room</h1>

<hr />

<div class="row">
    <div class="col-md-6 col-lg-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="RoomNumber" class="control-label">Room Number *</label>
                <input asp-for="RoomNumber" class="form-control" placeholder="e.g. 101, A12" />
                <span asp-validation-for="RoomNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-4 form-check">
                <input class="form-check-input" asp-for="IsAvailable" checked />
                <label class="form-check-label" asp-for="IsAvailable">Is Available</label>
                <span asp-validation-for="IsAvailable" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RoomTypeId" class="control-label">Room Type *</label>
                <select asp-for="RoomTypeId" class="form-control" asp-items="ViewBag.RoomTypeId">
                    <option value="">-- Select room type --</option>
                </select>
                <span asp-validation-for="RoomTypeId" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group mt-4">
                <input type="submit" value="Create Room" class="btn btn-primary me-2" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}