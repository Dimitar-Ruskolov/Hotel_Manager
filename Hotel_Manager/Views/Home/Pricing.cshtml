@{
    ViewData["Title"] = "Цени";
    ViewData["HideNavbar"] = true;

    var roomTypes = ViewBag.RoomTypes as IEnumerable<dynamic>;
    var services = ViewBag.Services as IEnumerable<dynamic>;
}

<div class="home-hero">
    <div class="container py-5">

        <a class="btn btn-outline-light mb-4" asp-controller="Home" asp-action="Index">← Назад</a>

        <h1 class="text-white text-center fw-bold mb-2">Цени</h1>
        <p class="text-white-50 text-center mb-5">
            Цени на стаи (на нощувка) и допълнителни услуги.
        </p>

        <div class="mb-5">
            <h3 class="text-white mb-3">Стаи</h3>

            <div class="row g-4">
                @if (roomTypes != null && roomTypes.Any())
                {
                    foreach (var rt in roomTypes)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm pricing-glass h-100">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="mb-1 text-white">@rt.Name</h5>
                                        <span class="badge rounded-pill text-bg-light">BGN</span>
                                    </div>

                                    <div class="mt-3">
                                        <div class="display-6 fw-bold text-white">@rt.PricePerNight</div>
                                        <div class="text-white-50">на нощувка</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-white-50">Няма налични типове стаи.</div>
                }
            </div>
        </div>

        <div class="mb-2">
            <h3 class="text-white mb-3">Удобства</h3>

            <div class="row g-3">
                @if (services != null && services.Any())
                {
                    foreach (var s in services)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm pricing-glass">
                                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                    <div class="text-white fw-semibold">@s.Name</div>
                                    <div class="text-white fw-bold">@s.Price BGN</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-white-50">Няма налични услуги.</div>
                }
            </div>
        </div>

    </div>
</div>