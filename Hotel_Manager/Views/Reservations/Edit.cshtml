@model Hotel_Manager.Models.Reservation

@{
    ViewData["Title"] = "Edit Reservation";
}

<h1>Edit Reservation</h1>

<div class="mb-4">
    <h4>Current Guest</h4>
    <p>@Model.User?.FirstName @Model.User?.LastName (@Model.User?.Email)</p>
    <small class="text-muted">Guest information cannot be changed here.</small>
</div>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Edit">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />

            <h4>Reservation Details</h4>
            <hr />

            <div class="form-group mb-3">
                <label asp-for="CheckInDate" class="control-label">Check-in Date <span class="text-danger">*</span></label>
                <input asp-for="CheckInDate" type="date" class="form-control" required />
                <span asp-validation-for="CheckInDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CheckOutDate" class="control-label">Check-out Date <span class="text-danger">*</span></label>
                <input asp-for="CheckOutDate" type="date" class="form-control" required id="checkout-date" />
                <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                <div class="invalid-feedback d-block" id="date-range-error"></div>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Status (auto)</label>
                <input asp-for="Status" class="form-control" disabled />
            </div>

            <div class="form-group mb-3">
                <label>Room Type</label>
                <select name="roomTypeId" class="form-control" asp-items="@(ViewData["RoomTypes"] as SelectList)" required></select>
            </div>

            <div class="form-group mb-3">
                <label>Additional Services (hold Ctrl to select multiple)</label>
                <select name="serviceIds" class="form-control" multiple asp-items="@(ViewData["Services"] as MultiSelectList)"></select>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Save Changes" class="btn btn-primary btn-lg" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const form          = document.querySelector('form');
            const checkInInput  = document.querySelector('input[name="CheckInDate"]');
            const checkOutInput = document.querySelector('input[name="CheckOutDate"]');
            const errorDiv      = document.getElementById('date-range-error');


            if (!form || !checkInInput || !checkOutInput) {
                console.warn('Date validation elements not found');
                return;
            }

            function validateDateRange() {
                if (!checkInInput.value || !checkOutInput.value) {
                    checkOutInput.classList.remove('is-invalid');
                    if (errorDiv) {
                        errorDiv.textContent = '';
                        errorDiv.style.display = 'none';
                    }
                    return true;
                }

                const checkIn = new Date(checkInInput.value);
                const checkOut = new Date(checkOutInput.value);


                const isValid = checkOut > checkIn;

                if (isValid) {
                    checkOutInput.classList.remove('is-invalid');
                    if (errorDiv) {
                        errorDiv.textContent = '';
                        errorDiv.style.display = 'none';
                    }
                } else {
                    checkOutInput.classList.add('is-invalid');
                    if (errorDiv) {
                        errorDiv.textContent = checkOut.getTime() === checkIn.getTime()
                            ? 'Check-out must be **after** check-in (same day not allowed)'
                            : 'Check-out must be after check-in date.';
                        errorDiv.style.display = 'block';
                    }
                }

                return isValid;
            }

            checkInInput.addEventListener('change', function () {
                if (this.value) {
                    checkOutInput.min = this.value;
                } else {
                    checkOutInput.removeAttribute('min');
                }
                validateDateRange();
            });

            checkOutInput.addEventListener('change', validateDateRange);

            form.addEventListener('submit', function (e) {
                const isValid = validateDateRange();

                if (!isValid) {
                    e.preventDefault();
                    checkOutInput.focus();
                }
            });

            if (checkInInput.value) {
                checkOutInput.min = checkInInput.value;
                validateDateRange();
            }
        });
    </script>
}