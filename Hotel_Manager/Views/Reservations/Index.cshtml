@model IEnumerable<Hotel_Manager.Models.Reservation>

@{
    ViewData["Title"] = User.IsInRole("Guest") ? "My Reservations" : "Reservations";
}

<h1>@ViewData["Title"]</h1>

@if (ViewBag.ShowCreateButton == true)
{
    <p>
        <a asp-action="Create" class="btn btn-success">Create New Reservation</a>
    </p>
}

@if (TempData["NewGuestEmail"] != null && TempData["NewGuestPassword"] != null)
{
    <div class="alert alert-warning mt-3">
        <h5>New guest account created!</h5>
        <p>
            <strong>Email:</strong> @TempData["NewGuestEmail"]<br />
            <strong>Generated Password:</strong>
            <code class="bg-light p-2 border">@TempData["NewGuestPassword"]</code>
        </p>
        <small class="text-danger">This password is shown only once! Save it securely.</small>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted mt-4">
        @(User.IsInRole("Guest") ? "You don't have any reservations yet." : "No reservations found.")
    </p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Guest</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Room(s)</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var statusClass = item.Status switch
                {
                    "Completed" => "bg-success",
                    "In Progress" => "bg-info",
                    "Upcoming" => "bg-warning",
                    "Cancelled" => "bg-danger",
                    _ => "bg-secondary"
                };

                <tr>
                    <td>@(item.User?.FirstName ?? "Unknown") @(item.User?.LastName ?? "")</td>
                    <td>@item.CheckInDate.ToShortDateString()</td>
                    <td>@item.CheckOutDate.ToShortDateString()</td>
                    <td>
                        @foreach (var rr in item.ReservationRooms)
                        {
                            <div>
                                @rr.Room?.RoomNumber (@rr.Room?.RoomType?.Name)
                            </div>
                        }
                    </td>
                    <td>@item.TotalPrice.ToString("C")</td>
                    <td>
                        <span class="badge @statusClass">@item.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (ViewBag.ShowCreateButton == true)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                               onclick="return confirm('Are you sure you want to delete this reservation?');">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}